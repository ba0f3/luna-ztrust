# Luna Z-Trust — production central server (luna-proxy)
#
# Setup:
#   cp deploy/.env.production.example /etc/luna/luna-proxy.env
#   chmod 600 /etc/luna/luna-proxy.env
#   Edit paths and Telegram values; do NOT put the key passphrase here.
#
# After start, unseal via admin mTLS:
#   POST /api/v1/admin/unseal  {"passphrase":"..."}
#
# Load in systemd:
#   EnvironmentFile=/etc/luna/luna-proxy.env

# Runtime (never set dev in production)
# LUNA_ENV=dev

LUNA_LISTEN_ADDR=:8443

# Encrypted OpenSSH PEM; chmod 400; owner root or dedicated luna user
LUNA_KEY_PATH=/etc/luna/ssh/encrypted_ca.key
LUNA_SIGNER_MODE=local-ca
# LUNA_SIGNER_MODE=local-key
# LUNA_KEY_PATH=/etc/luna/ssh/encrypted_host.key

LUNA_ADMIN_CLIENT_OU=luna-admin
LUNA_APPROVAL_TIMEOUT=60s

# mTLS server + client CA (issue automation certs separately)
LUNA_MTLS_SERVER_CERT=/etc/luna/certs/server.crt
LUNA_MTLS_SERVER_KEY=/etc/luna/certs/server.key
LUNA_MTLS_CLIENT_CA=/etc/luna/certs/ca.crt

# Telegram OOB approval (required when LUNA_ENV is not dev)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_CHAT_ID=

# Mobile push (P5 — stub until implemented)
# FCM_CREDENTIALS=

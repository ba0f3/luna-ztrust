# Luna Z-Trust — luna-agent on a client/automation host
#
# Setup:
#   cp deploy/.env.agent.example /etc/luna/luna-agent.env
#   chmod 600 /etc/luna/luna-agent.env
#
# LUNA_SIGNER_MODE must match the central luna-proxy configuration.
# LUNA_TARGET_HOST is used for PoP binding (OpenSSH does not pass remote host to Sign).

LUNA_PROXY_URL=https://luna-proxy.example.com:8443
LUNA_SIGNER_MODE=local-ca

LUNA_MTLS_CERT=/etc/luna/certs/client.crt
LUNA_MTLS_KEY=/etc/luna/certs/client.key
LUNA_MTLS_CA=/etc/luna/certs/ca.crt

LUNA_TARGET_USER=deploy
LUNA_TARGET_HOST=203.0.113.10

LUNA_AGENT_SOCKET=/run/luna/agent.sock

# Luna Z-Trust — environment variable reference
#
# Copy the profile that matches your use case:
#
#   Local dev / CI / E2E     →  cp .env.testing.example .env.testing
#                              cp luna-proxy.testing.example.yaml proxy.yml
#                              cp luna-agent.testing.example.yaml agent.yml
#   Production luna-proxy    →  cp deploy/.env.production.example /etc/luna/luna-proxy.env
#                              cp deploy/luna-proxy.production.example.yaml /etc/luna/proxy.yml
#   Production luna-agent    →  cp deploy/.env.agent.example /etc/luna/luna-agent.env
#                              cp deploy/luna-agent.example.yaml /etc/luna/agent.yml
#
# Config loading (Viper): defaults → YAML files (merged) → .env → environment variables (env wins).
# Merge order (later overrides earlier): ./proxy.yml, ~/.config/luna/proxy.yml, /etc/luna/proxy.yml
# Agent: ./agent.yml, ~/.config/luna/agent.yml, /etc/luna/agent.yml
# Or set LUNA_CONFIG=/path/to/config.yml
#
# Never commit real .env files or proxy.yml / agent.yml with tokens or passphrases.
# Key passphrases are supplied only via POST /api/v1/admin/unseal (not env vars).
#
# Generate local test material:
#   make testdata
#
# See README.md for API overview and docs/setup.md for target sshd trust.

# Quick local testing (see .env.testing.example for full file):
# LUNA_ENV=dev
# LUNA_KEY_PATH=./testdata/ssh/encrypted_ca.key
# LUNA_PROXY_URL=https://localhost:8443

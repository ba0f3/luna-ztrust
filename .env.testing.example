# Luna Z-Trust — local testing environment
#
# Setup:
#   make testdata          # generates testdata/ca and testdata/ssh
#   cp .env.testing.example .env.testing
#   set -a && source .env.testing && set +a
#
# Or use YAML config instead (see luna-proxy.testing.example.yaml / luna-agent.testing.example.yaml):
#   cp luna-proxy.testing.example.yaml proxy.yml
#   cp luna-agent.testing.example.yaml agent.yml
#
# Start proxy (sealed until key load):
#   ./bin/luna-proxy serve
#
# Load signing key (passphrase for testdata/ssh keys is test-pass):
#   ./bin/luna-proxy key load ./testdata/ssh/encrypted_ca.key
#   ./bin/luna-proxy status
#
# With LUNA_ENV=dev the proxy auto-approves sign requests (no Telegram).

# --- luna-proxy (central) ---

LUNA_ENV=dev
LUNA_LISTEN_ADDR=:8443

# Encrypted signing key (from make testdata; passphrase: test-pass)
LUNA_KEY_PATH=./testdata/ssh/encrypted_ca.key
LUNA_SIGNER_MODE=local-ca
# LUNA_SIGNER_MODE=local-key
# LUNA_KEY_PATH=./testdata/ssh/encrypted_host.key

LUNA_ADMIN_CLIENT_OU=luna-admin
LUNA_APPROVAL_TIMEOUT=60s

# Server mTLS (testdata CA)
LUNA_MTLS_SERVER_CERT=./testdata/ca/server.crt
LUNA_MTLS_SERVER_KEY=./testdata/ca/server.key
LUNA_MTLS_CLIENT_CA=./testdata/ca/ca.crt

# Telegram (optional in dev — leave empty when LUNA_ENV=dev)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_CHAT_ID=

# --- luna-agent (client) ---

LUNA_PROXY_URL=https://localhost:8443
LUNA_SIGNER_MODE=local-ca

LUNA_MTLS_CERT=./testdata/ca/client.crt
LUNA_MTLS_KEY=./testdata/ca/client.key
LUNA_MTLS_CA=./testdata/ca/ca.crt

LUNA_TARGET_USER=deploy
LUNA_TARGET_HOST=127.0.0.1
LUNA_AGENT_SOCKET=/tmp/luna-agent.sock

# --- SDK / E2E tests ---

LUNA_PROXY_URL=https://localhost:8443
